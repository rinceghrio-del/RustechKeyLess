<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Glow title - uses a custom GlowTextView or standard with shadow -->
                    <TextView
                        android:id="@+id/tvAppTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RUSTECH KEYLESS"
                        android:textColor="@color/accent_green"
                        android:textSize="26sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="sans-serif-medium"
                        android:shadowColor="#8000E87A"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="18" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLE BEACON CONTROL CENTER"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.14"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- BLE status pill -->
                <LinearLayout
                    android:id="@+id/layoutBlePill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/bg_pill_green"
                    android:layout_marginTop="15dp">

                    <View
                        android:id="@+id/bleDot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_dot_green"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLE Active"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"/>

                </LinearLayout>

            </FrameLayout>

            <!-- ═══════════════════════════════ TABS ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp">

                <Button
                    android:id="@+id/btnTabBroadcast"
                    style="@style/Widget.Rustech.TabButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BROADCAST"
                    android:textColor="@color/accent_green"
                    android:background="@drawable/bg_tab_active"/>

                <Button
                    android:id="@+id/btnTabScope"
                    style="@style/Widget.Rustech.TabButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SCOPE"
                    android:textColor="@color/text_secondary"
                    android:background="@android:color/transparent"/>

            </LinearLayout>

            <!-- ═══════════════════════ BROADCAST TAB CONTENT ═══════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutBroadcast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- UUID Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BEACON UUID"
                            android:textColor="@color/accent_green"
                            android:textSize="10sp"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="10dp"/>

                        <!-- UUID display box -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Rustech.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUuid"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_mono"
                                android:textSize="13sp"
                                android:fontFamily="monospace"
                                android:inputType="text"
                                android:singleLine="true"
                                android:background="@null"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Generate button -->
                        <Button
                            android:id="@+id/btnRandomUuid"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="⟳  GENERATE RANDOM UUID"
                            android:textColor="@color/accent_green"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:minWidth="0dp"
                            app:rippleColor="@color/accent_green_faint"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Major / Minor row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="14dp"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Rustech.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="7dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MAJOR"
                                android:textColor="@color/accent_green"
                                android:textSize="10sp"
                                android:letterSpacing="0.15"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="6dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Rustech.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etMajor"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_primary"
                                    android:textSize="22sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:inputType="number"
                                    android:background="@null"/>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Rustech.Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="7dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MINOR"
                                android:textColor="@color/accent_green"
                                android:textSize="10sp"
                                android:letterSpacing="0.15"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="6dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Rustech.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etMinor"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_primary"
                                    android:textSize="22sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:inputType="number"
                                    android:background="@null"/>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Device Label Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEVICE LABEL"
                            android:textColor="@color/accent_green"
                            android:textSize="10sp"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Rustech.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLabel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-medium"
                                android:inputType="text"
                                android:background="@null"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Save Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveSettings"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="28dp"
                    android:text="SAVE SETTINGS"
                    android:textColor="@color/accent_green"
                    android:textSize="13sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/accent_green_faint"
                    app:strokeColor="@color/accent_green_border"
                    app:strokeWidth="1dp"
                    app:cornerRadius="14dp"
                    app:rippleColor="@color/accent_green_faint"/>

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/accent_green_border"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRANSMITTER"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/accent_green_border"/>

                </LinearLayout>

                <!-- Broadcast Toggle Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBroadcast"
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Toggle row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Broadcasting"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium"/>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchBroadcast"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="@color/text_primary"
                                app:trackTint="@color/accent_orange"/>

                        </LinearLayout>

                        <!-- Status text -->
                        <TextView
                            android:id="@+id/tvBroadcastStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stopped"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"/>

                        <!-- Stats row (shown when broadcasting) -->
                        <LinearLayout
                            android:id="@+id/layoutBroadcastStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="14dp"
                            android:visibility="gone">

                            <!-- divider above stats -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:background="@color/accent_green_border"
                                    android:layout_marginBottom="14dp"/>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="TX POWER"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="9sp"
                                            android:letterSpacing="0.12"
                                            android:layout_marginBottom="2dp"/>
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="-59 dBm"
                                            android:textColor="@color/accent_green"
                                            android:textSize="15sp"
                                            android:fontFamily="monospace"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="MODE"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="9sp"
                                            android:letterSpacing="0.12"
                                            android:layout_marginBottom="2dp"/>
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="iBeacon"
                                            android:textColor="@color/accent_green"
                                            android:textSize="15sp"
                                            android:fontFamily="monospace"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="LATENCY"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="9sp"
                                            android:letterSpacing="0.12"
                                            android:layout_marginBottom="2dp"/>
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="LOW"
                                            android:textColor="@color/accent_green"
                                            android:textSize="15sp"
                                            android:fontFamily="monospace"/>
                                    </LinearLayout>

                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ═══════════════════════ SCOPE TAB CONTENT ═══════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutScope"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Scan toggle card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scanning"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detect nearby iBeacons"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchScan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/text_primary"
                            app:trackTint="@color/accent_orange"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Radar card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="16dp">

                    <com.rustech.keyless.ScopeView
                        android:id="@+id/scopeView"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"/>

                </com.google.android.material.card.MaterialCardView>

                <!-- Range labels card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Rustech.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Near\n0–4 m"
                            android:textColor="@color/accent_green"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:fontFamily="monospace"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/accent_green_border"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mid\n4–10 m"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:fontFamily="monospace"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/accent_green_border"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Far\n10–15 m"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:fontFamily="monospace"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Beacon list label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETECTED BEACONS"
                    android:textColor="@color/accent_green"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="24dp"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBeacons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_beacon"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
