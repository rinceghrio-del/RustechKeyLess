<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/accent_green_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Left: dot indicator -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_green"
            android:layout_marginEnd="14dp"/>

        <!-- Center: title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBeaconTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="3dp"
                tools:text="Major:1  Minor:1"
                xmlns:tools="http://schemas.android.com/tools"/>

            <TextView
                android:id="@+id/tvBeaconSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                tools:text="f3298da6…  ·  2.4 m  ·  AA:BB:CC:DD:EE:FF"
                xmlns:tools="http://schemas.android.com/tools"/>

        </LinearLayout>

        <!-- Right: RSSI badge -->
        <TextView
            android:id="@+id/tvBeaconRssi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:fontWeight="500"
            android:layout_marginStart="12dp"
            tools:text="-72 dBm"
            xmlns:tools="http://schemas.android.com/tools"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
